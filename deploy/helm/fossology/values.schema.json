{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "fullnameOverride": {
      "type": "string"
    },
    "images": {
      "type": "object",
      "properties": {
        "web": {
          "$ref": "#/definitions/image"
        },
        "worker": {
          "$ref": "#/definitions/image"
        },
        "postgres": {
          "$ref": "#/definitions/image"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "ssh": {
      "type": "object",
      "properties": {
        "privateSecretName": {
          "type": "string",
          "minLength": 1
        },
        "publicSecretName": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "privateSecretName",
        "publicSecretName"
      ]
    },
    "database": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "user": {
          "type": "string",
          "minLength": 1
        },
        "password": {
          "type": "string"
        },
        "dbConfSecretName": {
          "type": "string"
        },
        "internal": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "persistence": {
              "$ref": "#/definitions/persistence"
            }
          }
        }
      },
      "required": [
        "name",
        "user",
        "password"
      ]
    },
    "repoPersistence": {
      "allOf": [
        {
          "$ref": "#/definitions/persistence"
        },
        {
          "type": "object",
          "properties": {
            "existingClaim": {
              "type": "string"
            }
          }
        }
      ]
    },
    "web": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "service": {
          "$ref": "#/definitions/service"
        },
        "startupProbe": {
          "$ref": "#/definitions/probe"
        },
        "readinessProbe": {
          "$ref": "#/definitions/probe"
        },
        "livenessProbe": {
          "$ref": "#/definitions/probe"
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "workers": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "podManagementPolicy": {
          "type": "string",
          "enum": [
            "OrderedReady",
            "Parallel"
          ]
        },
        "maxAgentsPerWorker": {
          "type": "integer",
          "minimum": 1
        },
        "minReadyStartup": {
          "type": "integer",
          "minimum": 1
        },
        "minReadySync": {
          "type": "integer",
          "minimum": 1
        },
        "readinessProbe": {
          "$ref": "#/definitions/probe"
        },
        "livenessProbe": {
          "$ref": "#/definitions/probe"
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "runtimeConfig": {
      "type": "object",
      "properties": {
        "startupPollIntervalSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "pollIntervalSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "postInstallJob": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "backoffLimit": {
          "type": "integer",
          "minimum": 0
        },
        "ttlSecondsAfterFinished": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object"
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "path",
                    "pathType"
                  ]
                }
              }
            },
            "required": [
              "host",
              "paths"
            ]
          }
        },
        "tls": {
          "type": "array"
        }
      }
    }
  },
  "definitions": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": [
            "string",
            "number"
          ]
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      },
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ]
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        }
      },
      "required": [
        "accessModes",
        "size"
      ]
    },
    "probe": {
      "type": "object",
      "properties": {
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "initialDelaySeconds",
        "periodSeconds"
      ]
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "nodePort": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 30000,
          "maximum": 32767
        }
      },
      "required": [
        "type",
        "port",
        "targetPort"
      ]
    }
  }
}
